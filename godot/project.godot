; Godot 4.2+ — CatSpy desktop rebuild
; Open in Godot Editor once to generate .import files for PNGs.

config_version=5

[application]

config/name="CatSpy"
config/description="2D stealth — Godot rebuild (see docs/contracts/godot-room-runtime.md)"
run/main_scene="res://scenes/ui/Title.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")

[autoload]

Game="*res://scripts/autoload/game.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"

[input]

[layer_names]

2d_physics/layer_1="world"
2d_physics/layer_2="player"

[physics]

2d/default_gravity=980

[rendering]

textures/canvas_textures/default_texture_filter=0
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
